# WaxFlow Configuration

# Spotify Developer App credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8402/api/spotify/callback

# Tidal downloader (optional -- only needed if running Tidarr as fallback)
# TIDARR_URL=http://localhost:8484

# Lexicon DJ API
LEXICON_API_URL=http://localhost:48624

# Web UI API URL (for Next.js rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8402

# CORS origins for API
CORS_ORIGINS=http://localhost:8400

# Music library path (inside container)
MUSIC_LIBRARY_PATH=/music
