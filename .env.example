# Spotify Developer App credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://192.168.1.221:8402/api/spotify/callback

# Tidarr (Tidal FLAC downloader)
TIDARR_URL=http://192.168.1.221:8484

# Lexicon DJ API (Mac Mini)
LEXICON_API_URL=http://192.168.1.116:48624

# Web UI API URL (for Next.js rewrites)
NEXT_PUBLIC_API_URL=http://192.168.1.221:8402

# CORS origins for API
CORS_ORIGINS=http://localhost:8400,http://192.168.1.221:8400

# Music library path (inside container)
MUSIC_LIBRARY_PATH=/music
